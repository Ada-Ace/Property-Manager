# Property Management Application Environment Variables
# Copy this file to .env and fill in the values

# App Configuration
VITE_APP_NAME="PropManage Pro"

# Manager Credentials (Required for initial admin setup)
VITE_MANAGER_EMAIL="your-email@domain.com"
VITE_MANAGER_PASSWORD="secure-password-here"
VITE_MANAGER_MOBILE="+1234567890"

# API Configuration (Paste your Google Apps Script Web App URL after deploying)
VITE_API_URL="https://script.google.com/macros/s/.../exec"
